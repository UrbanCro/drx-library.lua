local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Remove old instance
if CoreGui:FindFirstChild("DRXGUI") then
    CoreGui:FindFirstChild("DRXGUI"):Destroy()
    wait(0.1)
end

-- Colors - Muted and clean
