--[[
  options = {
    MusicId = "rbxassetid://XXXXXXXXXX",  -- audio to play during loading
    Logo    = "D · R · X",               -- big title on loading screen
  }
--]]
function Library:CreateWindow(title, options)
    options = options or {}
    local musicId  = options.MusicId or nil
    local logoText = options.Logo    or "D · R · X"

    local Win      = {}
    Win.Tabs       = {}
