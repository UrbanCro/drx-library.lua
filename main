    -- ════════════════════════════════════════════
    -- ELEMENT BUILDERS
    -- ════════════════════════════════════════════
    local function EButton(parent, text, cb)
        local B = Instance.new("TextButton")
        B.Size             = UDim2.new(1, 0, 0, 36)
        B.BackgroundColor3 = C.Elevated
        B.BorderSizePixel  = 0
        B.Font             = Enum.Font.Gotham
        B.Text             = text
        B.TextColor3       = C.TxtHi
        B.TextSize         = 13
        B.AutoButtonColor  = false
        B.Parent           = parent
        Corner(B, 8)
        B.MouseEnter:Connect(function()  Tw(B, {BackgroundColor3 = C.Primary}) end)
        B.MouseLeave:Connect(function()  Tw(B, {BackgroundColor3 = C.Elevated}) end)
        B.MouseButton1Click:Connect(function() if cb then pcall(cb) end end)
        return B
    end

    local function EToggle(parent, text, default, cb)
        local state = (default == true)
        local Row = Instance.new("Frame")
        Row.Size             = UDim2.new(1, 0, 0, 36)
        Row.BackgroundColor3 = C.Elevated
        Row.BorderSizePixel  = 0
        Row.Parent           = parent
        Corner(Row, 8)

        local Lbl = Instance.new("TextLabel")
        Lbl.Size               = UDim2.new(1, -58, 1, 0)
        Lbl.Position           = UDim2.new(0, 12, 0, 0)
        Lbl.BackgroundTransparency = 1
        Lbl.Font               = Enum.Font.Gotham
        Lbl.Text               = text
        Lbl.TextColor3         = C.TxtHi
        Lbl.TextSize           = 13
        Lbl.TextXAlignment     = Enum.TextXAlignment.Left
        Lbl.Parent             = Row

        local Track = Instance.new("Frame")
        Track.Size             = UDim2.new(0, 42, 0, 22)
        Track.Position         = UDim2.new(1, -50, 0.5, 0)
        Track.AnchorPoint      = Vector2.new(0, 0.5)
        Track.BackgroundColor3 = state and C.Success or C.Surface
        Track.BorderSizePixel  = 0
        Track.Parent           = Row
        Corner(Track, 11)

        local Knob = Instance.new("Frame")
        Knob.Size             = UDim2.new(0, 18, 0, 18)
        Knob.Position         = state and UDim2.new(1,-20,0.5,0) or UDim2.new(0,2,0.5,0)
        Knob.AnchorPoint      = Vector2.new(0, 0.5)
        Knob.BackgroundColor3 = C.TxtHi
        Knob.BorderSizePixel  = 0
        Knob.Parent           = Track
        Corner(Knob, 9)

        local Hit = Instance.new("TextButton")
        Hit.Size                   = UDim2.new(1, 0, 1, 0)
        Hit.BackgroundTransparency = 1
        Hit.Text                   = ""
        Hit.Parent                 = Track
        Hit.MouseButton1Click:Connect(function()
            state = not state
            Tw(Track, {BackgroundColor3 = state and C.Success or C.Surface})
            Tw(Knob,  {Position         = state and UDim2.new(1,-20,0.5,0) or UDim2.new(0,2,0.5,0)})
            if cb then pcall(cb, state) end
        end)

        return {
            GetValue        = function() return state end,
            SetValue        = function(v, fire)
                state = v
                Track.BackgroundColor3 = state and C.Success or C.Surface
                Knob.Position          = state and UDim2.new(1,-20,0.5,0) or UDim2.new(0,2,0.5,0)
                if fire and cb then pcall(cb, state) end
            end,
            TriggerCallback = function() if cb then pcall(cb, state) end end,
        }
    end

    local function ESlider(parent, text, mn, mx, def, cb)
        local val = math.clamp(def, mn, mx)
        local Box = Instance.new("Frame")
        Box.Size             = UDim2.new(1, 0, 0, 52)
        Box.BackgroundColor3 = C.Elevated
        Box.BorderSizePixel  = 0
        Box.Parent           = parent
        Corner(Box, 8)

        local Lbl = Instance.new("TextLabel")
        Lbl.Size               = UDim2.new(1, -62, 0, 20)
        Lbl.Position           = UDim2.new(0, 12, 0, 6)
        Lbl.BackgroundTransparency = 1
        Lbl.Font               = Enum.Font.Gotham
        Lbl.Text               = text
        Lbl.TextColor3         = C.TxtHi
        Lbl.TextSize           = 13
        Lbl.TextXAlignment     = Enum.TextXAlignment.Left
        Lbl.Parent             = Box

        local ValLbl = Instance.new("TextLabel")
        ValLbl.Size               = UDim2.new(0, 52, 0, 20)
        ValLbl.Position           = UDim2.new(1, -58, 0, 6)
        ValLbl.BackgroundTransparency = 1
        ValLbl.Font               = Enum.Font.GothamBold
        ValLbl.Text               = tostring(val)
        ValLbl.TextColor3         = C.Primary
        ValLbl.TextSize           = 13
        ValLbl.TextXAlignment     = Enum.TextXAlignment.Right
        ValLbl.Parent             = Box

        local Trk = Instance.new("Frame")
        Trk.Size             = UDim2.new(1, -24, 0, 4)
        Trk.Position         = UDim2.new(0, 12, 1, -14)
        Trk.BackgroundColor3 = C.Surface
        Trk.BorderSizePixel  = 0
        Trk.Parent           = Box
        Corner(Trk, 2)

        local Fill = Instance.new("Frame")
        Fill.Size             = UDim2.new((val-mn)/(mx-mn), 0, 1, 0)
        Fill.BackgroundColor3 = C.Primary
        Fill.BorderSizePixel  = 0
        Fill.Parent           = Trk
        Corner(Fill, 2)

        local Knob = Instance.new("Frame")
        Knob.Size             = UDim2.new(0, 14, 0, 14)
        Knob.Position         = UDim2.new((val-mn)/(mx-mn), 0, 0.5, 0)
        Knob.AnchorPoint      = Vector2.new(0.5, 0.5)
        Knob.BackgroundColor3 = C.TxtHi
        Knob.BorderSizePixel  = 0
        Knob.Parent           = Trk
        Corner(Knob, 7)

        local drag = false
        local function Apply(ix)
            local pct = math.clamp((ix - Trk.AbsolutePosition.X) / Trk.AbsoluteSize.X, 0, 1)
            val = math.floor(mn + pct*(mx-mn))
            ValLbl.Text   = tostring(val)
            Fill.Size     = UDim2.new(pct, 0, 1, 0)
            Knob.Position = UDim2.new(pct, 0, 0.5, 0)
            if cb then pcall(cb, val) end
        end
        Trk.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag=true Apply(i.Position.X) end
        end)
        Knob.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag=true end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag=false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then Apply(i.Position.X) end
        end)

        return {
            GetValue        = function() return val end,
            SetValue        = function(v, fire)
                val = math.floor(math.clamp(v, mn, mx))
                local pct = (val-mn)/(mx-mn)
                ValLbl.Text   = tostring(val)
                Fill.Size     = UDim2.new(pct, 0, 1, 0)
                Knob.Position = UDim2.new(pct, 0, 0.5, 0)
                if fire and cb then pcall(cb, val) end
            end,
            TriggerCallback = function() if cb then pcall(cb, val) end end,
        }
    end

    local function ELabel(parent, text)
        local F = Instance.new("Frame")
        F.Size             = UDim2.new(1, 0, 0, 26)
        F.BackgroundColor3 = C.BG
        F.BackgroundTransparency = 0.35
        F.BorderSizePixel  = 0
        F.Parent           = parent
        Corner(F, 6)
        local L = Instance.new("TextLabel")
        L.Size               = UDim2.new(1, -12, 1, 0)
        L.Position           = UDim2.new(0, 12, 0, 0)
        L.BackgroundTransparency = 1
        L.Font               = Enum.Font.GothamBold
        L.Text               = text
        L.TextColor3         = C.TxtSub
        L.TextSize           = 11
        L.TextXAlignment     = Enum.TextXAlignment.Left
        L.Parent             = F
        return { SetText = function(t) L.Text = t end }
    end

    local function ETextbox(parent, placeholder, cb)
        local F = Instance.new("Frame")
        F.Size             = UDim2.new(1, 0, 0, 36)
        F.BackgroundColor3 = C.Elevated
        F.BorderSizePixel  = 0
        F.Parent           = parent
        Corner(F, 8)
        Stroke(F, C.Border, 1)
        local TB = Instance.new("TextBox")
        TB.Size               = UDim2.new(1, -24, 1, 0)
        TB.Position           = UDim2.new(0, 12, 0, 0)
        TB.BackgroundTransparency = 1
        TB.Font               = Enum.Font.Gotham
        TB.PlaceholderText    = placeholder or ""
        TB.PlaceholderColor3  = C.TxtSub
        TB.Text               = ""
        TB.TextColor3         = C.TxtHi
        TB.TextSize           = 13
        TB.TextXAlignment     = Enum.TextXAlignment.Left
        TB.ClearTextOnFocus   = false
        TB.Parent             = F
        TB.FocusLost:Connect(function(enter)
            if enter and cb then pcall(cb, TB.Text) end
        end)
        return {
            GetText = function() return TB.Text end,
            SetText = function(t) TB.Text = t end,
            Clear   = function()  TB.Text = "" end,
        }
    end

    -- ════════════════════════════════════════════
    -- INTERNAL TAB BUILDER
    -- ════════════════════════════════════════════
    local function _BuildTab(name, order)
        local Tab = {}

        local TBtn = Instance.new("TextButton")
        TBtn.Name                   = name
        TBtn.Size                   = UDim2.new(1, -14, 0, 36)
        TBtn.BackgroundColor3       = C.Elevated
        TBtn.BackgroundTransparency = 0.55
        TBtn.BorderSizePixel        = 0
        TBtn.Font                   = Enum.Font.Gotham
        TBtn.Text                   = name
        TBtn.TextColor3             = C.TxtSub
        TBtn.TextSize               = 13
        TBtn.AutoButtonColor        = false
        TBtn.LayoutOrder            = order
        TBtn.Parent                 = Sidebar
        Corner(TBtn, 8)
        Pad(TBtn, 0, 0, 10, 0)

        local Scr = Instance.new("ScrollingFrame")
        Scr.Name                   = name.."_Content"
        Scr.Size                   = UDim2.new(1, 0, 1, 0)
        Scr.BackgroundTransparency = 1
        Scr.BorderSizePixel        = 0
        Scr.ScrollBarThickness     = 4
        Scr.ScrollBarImageColor3   = C.Primary
        Scr.CanvasSize             = UDim2.new(0, 0, 0, 0)
        Scr.Visible                = false
        Scr.Parent                 = ContentArea

        local LL = Instance.new("UIListLayout")
        LL.Padding   = UDim.new(0, 8)
        LL.SortOrder = Enum.SortOrder.LayoutOrder
        LL.Parent    = Scr
        Pad(Scr, 7, 7, 7, 11)

        LL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Scr.CanvasSize = UDim2.new(0, 0, 0, LL.AbsoluteContentSize.Y + 14)
        end)

        TBtn.MouseButton1Click:Connect(function()
            for _, t in ipairs(Win.Tabs) do
                Tw(t.Button, {BackgroundTransparency = 0.55, TextColor3 = C.TxtSub})
                t.Content.Visible = false
            end
            Tw(TBtn, {BackgroundTransparency = 0, TextColor3 = C.TxtHi})
            Scr.Visible = true
        end)

        Tab.Button  = TBtn
        Tab.Content = Scr

        function Tab:AddButton(text, cb)           return EButton(Scr,  text, cb) end
        function Tab:AddToggle(text, def, cb)
            local e = EToggle(Scr, text, def, cb)
            Win._cfg[text] = e
            return e
        end
        function Tab:AddSlider(text, mn, mx, def, cb)
            local e = ESlider(Scr, text, mn, mx, def, cb)
            Win._cfg[text] = e
            return e
        end
        function Tab:AddLabel(text)                return ELabel(Scr,   text) end
        function Tab:AddTextbox(ph, cb)            return ETextbox(Scr, ph, cb) end

        return Tab
    end

    -- ─── Public CreateTab ───────────────────────
    function Win:CreateTab(name)
        local tab = _BuildTab(name, NextOrder())
        table.insert(Win.Tabs, tab)
        if #Win.Tabs == 1 then
            tab.Button.BackgroundTransparency = 0
            tab.Button.TextColor3             = C.TxtHi
            tab.Content.Visible               = true
        end
        return tab
    end

    -- ════════════════════════════════════════════
    -- SETTINGS TAB  (built after load, always order 9999)
    -- ════════════════════════════════════════════
    local function BuildSettingsTab()
        local ST  = _BuildTab("⚙  Settings", 9999)
        table.insert(Win.Tabs, ST)
        local Scr = ST.Content

        -- Config manager header
        ELabel(Scr, "CONFIG MANAGER")

        -- Name input
        local nameBox = ETextbox(Scr, "Enter config name...", nil)

        -- Scrollable config list
        local ListOuter = Instance.new("Frame")
        ListOuter.Size             = UDim2.new(1, 0, 0, 185)
        ListOuter.BackgroundColor3 = C.Surface
        ListOuter.BorderSizePixel  = 0
        ListOuter.Parent           = Scr
        Corner(ListOuter, 8)
        Stroke(ListOuter, C.Border, 1)

        local ListScr = Instance.new("ScrollingFrame")
        ListScr.Size                   = UDim2.new(1, -8, 1, -8)
        ListScr.Position               = UDim2.new(0, 4, 0, 4)
        ListScr.BackgroundTransparency = 1
        ListScr.BorderSizePixel        = 0
        ListScr.ScrollBarThickness     = 3
        ListScr.ScrollBarImageColor3   = C.Primary
        ListScr.CanvasSize             = UDim2.new(0, 0, 0, 0)
        ListScr.Parent                 = ListOuter

        local ListLL = Instance.new("UIListLayout")
        ListLL.Padding   = UDim.new(0, 4)
        ListLL.SortOrder = Enum.SortOrder.LayoutOrder
        ListLL.Parent    = ListScr
        Pad(ListScr, 5, 5, 5, 5)

        ListLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            ListScr.CanvasSize = UDim2.new(0, 0, 0, ListLL.AbsoluteContentSize.Y + 10)
        end)

        local EmptyLbl = Instance.new("TextLabel")
        EmptyLbl.Size               = UDim2.new(1, 0, 0, 28)
        EmptyLbl.BackgroundTransparency = 1
        EmptyLbl.Font               = Enum.Font.Gotham
        EmptyLbl.Text               = "No saved configs"
        EmptyLbl.TextColor3         = C.TxtSub
        EmptyLbl.TextSize           = 12
        EmptyLbl.Parent             = ListScr

        local selName = nil   -- currently selected config name
        local selRow  = nil   -- currently selected row frame

        local function RefreshList()
            for _, ch in ipairs(ListScr:GetChildren()) do
                if ch:IsA("Frame") then ch:Destroy() end
            end
            local configs = GetConfigList()
            EmptyLbl.Visible = (#configs == 0)

            for i, cfgName in ipairs(configs) do
                local Row = Instance.new("Frame")
                Row.Size             = UDim2.new(1, 0, 0, 36)
                Row.BackgroundColor3 = (selName == cfgName)
                    and Color3.fromRGB(38, 38, 80) or C.Elevated
                Row.BorderSizePixel  = 0
                Row.LayoutOrder      = i
                Row.Parent           = ListScr
                Corner(Row, 7)

                local NLbl = Instance.new("TextLabel")
                NLbl.Size               = UDim2.new(1, -100, 1, 0)
                NLbl.Position           = UDim2.new(0, 12, 0, 0)
                NLbl.BackgroundTransparency = 1
                NLbl.Font               = Enum.Font.Gotham
                NLbl.Text               = cfgName
                NLbl.TextColor3         = C.TxtHi
                NLbl.TextSize           = 12
                NLbl.TextXAlignment     = Enum.TextXAlignment.Left
                NLbl.Parent             = Row

                local SelBtn = Instance.new("TextButton")
                SelBtn.Size             = UDim2.new(0, 82, 0, 26)
                SelBtn.Position         = UDim2.new(1, -87, 0.5, 0)
                SelBtn.AnchorPoint      = Vector2.new(0, 0.5)
                SelBtn.BackgroundColor3 = (selName == cfgName) and C.Primary or C.Surface
                SelBtn.BorderSizePixel  = 0
                SelBtn.Font             = Enum.Font.GothamBold
                SelBtn.Text             = (selName == cfgName) and "Selected" or "Select"
                SelBtn.TextColor3       = (selName == cfgName) and C.TxtHi or C.Primary
                SelBtn.TextSize         = 11
                SelBtn.AutoButtonColor  = false
                SelBtn.Parent           = Row
                Corner(SelBtn, 5)

                if selName == cfgName then selRow = Row end

                SelBtn.MouseEnter:Connect(function()
                    if selName ~= cfgName then Tw(SelBtn, {BackgroundColor3 = C.Elevated}) end
                end)
                SelBtn.MouseLeave:Connect(function()
                    if selName ~= cfgName then Tw(SelBtn, {BackgroundColor3 = C.Surface}) end
                end)

                SelBtn.MouseButton1Click:Connect(function()
                    -- Deselect old row
                    if selRow then
                        Tw(selRow, {BackgroundColor3 = C.Elevated})
                        local oldBtn = selRow:FindFirstChildOfClass("TextButton")
                        if oldBtn then
                            oldBtn.Text      = "Select"
                            oldBtn.TextColor3 = C.Primary
                            Tw(oldBtn, {BackgroundColor3 = C.Surface})
                        end
                    end
                    -- Select new
                    selName = cfgName
                    selRow  = Row
                    Tw(Row, {BackgroundColor3 = Color3.fromRGB(38, 38, 80)})
                    Tw(SelBtn, {BackgroundColor3 = C.Primary})
                    SelBtn.Text      = "Selected"
                    SelBtn.TextColor3 = C.TxtHi
                    nameBox.SetText(cfgName)
                end)
            end
        end

        -- ── Action buttons ──────────────────────
        local BtnRow = Instance.new("Frame")
        BtnRow.Size                   = UDim2.new(1, 0, 0, 36)
        BtnRow.BackgroundTransparency = 1
        BtnRow.BorderSizePixel        = 0
        BtnRow.Parent                 = Scr

        local BLL = Instance.new("UIListLayout")
        BLL.FillDirection = Enum.FillDirection.Horizontal
        BLL.Padding       = UDim.new(0, 5)
        BLL.SortOrder     = Enum.SortOrder.LayoutOrder
        BLL.Parent        = BtnRow

        local function ActionBtn(text, col, order, cb)
            local B = Instance.new("TextButton")
            B.AutomaticSize    = Enum.AutomaticSize.X
            B.Size             = UDim2.new(0, 0, 1, 0)
            B.BackgroundColor3 = col
            B.BorderSizePixel  = 0
            B.Font             = Enum.Font.GothamBold
            B.Text             = "  "..text.."  "
            B.TextColor3       = C.TxtHi
            B.TextSize         = 12
            B.AutoButtonColor  = false
            B.LayoutOrder      = order
            B.Parent           = BtnRow
            Corner(B, 7)
            local hov = C.Primary
            B.MouseEnter:Connect(function()  Tw(B, {BackgroundColor3 = hov}) end)
            B.MouseLeave:Connect(function()  Tw(B, {BackgroundColor3 = col}) end)
            B.MouseButton1Click:Connect(function() if cb then pcall(cb) end end)
            return B
        end

        -- SAVE
        ActionBtn("💾 Save",    C.Elevated, 1, function()
            local name = nameBox.GetText():match("^%s*(.-)%s*$")
            if name == "" then return end
            local data = {}
            for k, e in pairs(Win._cfg) do data[k] = e.GetValue() end
            if SaveCfg(name, data) then selName = name RefreshList() end
        end)

        -- LOAD
        ActionBtn("📂 Load",    C.Elevated, 2, function()
            local name = selName or nameBox.GetText():match("^%s*(.-)%s*$")
            if not name or name == "" then return end
            local data = LoadCfg(name)
            if not data then return end
            for k, e in pairs(Win._cfg) do
                if data[k] ~= nil then e.SetValue(data[k], false) end
            end
            task.wait(0.05)
            for k, e in pairs(Win._cfg) do
                if data[k] ~= nil then e.TriggerCallback() end
            end
        end)

        -- RESAVE (overwrite selected with current values)
        ActionBtn("♻ Resave",  C.Elevated, 3, function()
            local name = selName or nameBox.GetText():match("^%s*(.-)%s*$")
            if not name or name == "" then return end
            local data = {}
            for k, e in pairs(Win._cfg) do data[k] = e.GetValue() end
            if SaveCfg(name, data) then RefreshList() end
        end)

        -- DELETE
        ActionBtn("🗑 Delete",  C.Elevated, 4, function()
            local name = selName or nameBox.GetText():match("^%s*(.-)%s*$")
            if not name or name == "" then return end
            if DeleteCfg(name) then
                selName = nil selRow = nil
                nameBox.Clear()
                RefreshList()
            end
        end)

        -- ── Toggle key setting ──────────────────
        ELabel(Scr, "TOGGLE KEY")

        local toggleKey    = Enum.KeyCode.RightShift
        local listeningKey = false

        local KRow = Instance.new("Frame")
        KRow.Size             = UDim2.new(1, 0, 0, 36)
        KRow.BackgroundColor3 = C.Elevated
        KRow.BorderSizePixel  = 0
        KRow.Parent           = Scr
        Corner(KRow, 8)

        local KLbl = Instance.new("TextLabel")
        KLbl.Size               = UDim2.new(1, -110, 1, 0)
        KLbl.Position           = UDim2.new(0, 12, 0, 0)
        KLbl.BackgroundTransparency = 1
        KLbl.Font               = Enum.Font.Gotham
        KLbl.Text               = "Show / Hide GUI"
        KLbl.TextColor3         = C.TxtHi
        KLbl.TextSize           = 13
        KLbl.TextXAlignment     = Enum.TextXAlignment.Left
        KLbl.Parent             = KRow

        local KBtn = Instance.new("TextButton")
        KBtn.Size             = UDim2.new(0, 96, 0, 26)
        KBtn.Position         = UDim2.new(1, -102, 0.5, 0)
        KBtn.AnchorPoint      = Vector2.new(0, 0.5)
        KBtn.BackgroundColor3 = C.Surface
        KBtn.BorderSizePixel  = 0
        KBtn.Font             = Enum.Font.GothamBold
        KBtn.Text             = "RightShift"
        KBtn.TextColor3       = C.Primary
        KBtn.TextSize         = 11
        KBtn.AutoButtonColor  = false
        KBtn.Parent           = KRow
        Corner(KBtn, 6)

        KBtn.MouseButton1Click:Connect(function()
            if listeningKey then return end
            listeningKey    = true
            KBtn.Text       = "Press key..."
            KBtn.TextColor3 = C.Warn
            local conn
            conn = UserInputService.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.Keyboard then
                    toggleKey       = i.KeyCode
                    KBtn.Text       = i.KeyCode.Name
                    KBtn.TextColor3 = C.Primary
                    listeningKey    = false
                    conn:Disconnect()
                end
            end)
        end)

        UserInputService.InputBegan:Connect(function(i, gp)
            if not gp and i.KeyCode == toggleKey then
                Main.Visible = not Main.Visible
            end
        end)

        -- Populate config list
        RefreshList()

        return ST
    end

    -- ════════════════════════════════════════════
    -- DRAGGING
    -- ════════════════════════════════════════════
    local drag, dragStart, dragFrom = false, nil, nil
    TopBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag      = true
            dragStart = i.Position
            dragFrom  = Main.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            Main.Position = UDim2.new(
                dragFrom.X.Scale, dragFrom.X.Offset + d.X,
                dragFrom.Y.Scale, dragFrom.Y.Offset + d.Y
            )
        end
    end)

    -- ════════════════════════════════════════════
    -- LOADING SEQUENCE   ← total 20 seconds
    -- ════════════════════════════════════════════
    --  pct = % target for this step
    --  dur = seconds to get there (all dur values sum to 20)
    --  text = status message
    --  step = checkmark label
    local Steps = {
        {pct=8,   dur=1.5, text="Initializing DRX core runtime...",         step="Core runtime"},
        {pct=18,  dur=1.5, text="Hooking game metatable...",                step="Game hooks"},
        {pct=29,  dur=2.0, text="Resolving player and camera refs...",      step="Player refs"},
        {pct=41,  dur=2.0, text="Fetching remote configurations...",        step="Remote config"},
        {pct=53,  dur=2.0, text="Compiling ESP rendering pipeline...",      step="ESP pipeline"},
        {pct=65,  dur=2.0, text="Loading aimbot prediction engine...",      step="Aimbot engine"},
        {pct=76,  dur=1.5, text="Initializing loot scanner coroutines...",  step="Loot scanner"},
        {pct=86,  dur=1.5, text="Applying anti-detection patches...",       step="Anti-detect"},
        {pct=95,  dur=2.0, text="Verifying module integrity...",            step="Integrity check"},
        {pct=100, dur=2.0, text="All systems operational.",                 step="Ready"},
    }

    task.spawn(function()
        local prevPct = 0

        for _, step in ipairs(Steps) do
            StatusLbl.Text = step.text

            -- Smooth tween of the bar
            Tw(BarFill,
               {Size = UDim2.new(step.pct / 100, 0, 1, 0)},
               step.dur,
               Enum.EasingStyle.Sine,
               Enum.EasingDirection.InOut
            )

            -- Count-up the % number in sync using ease-in-out-sine
            local elapsed = 0
            local from    = prevPct
            local to      = step.pct
            while elapsed < step.dur do
                local dt  = task.wait(0.033)
                elapsed   = elapsed + dt
                local t0  = math.clamp(elapsed / step.dur, 0, 1)
                local ease = -(math.cos(math.pi * t0) - 1) / 2
                PctLbl.Text = math.floor(from + (to - from) * ease).."%"
            end
            PctLbl.Text = to.."%"
            prevPct     = to

            -- Add a ✓ line to the completed-steps box
            local Check = Instance.new("TextLabel")
            Check.Size               = UDim2.new(1, 0, 0, 14)
            Check.BackgroundTransparency = 1
            Check.Font               = Enum.Font.Gotham
            Check.Text               = "✓  "..step.step
            Check.TextColor3         = C.Success
            Check.TextSize           = 11
            Check.TextXAlignment     = Enum.TextXAlignment.Left
            Check.LayoutOrder        = prevPct
            Check.Parent             = StepBox
            -- Trim to last 4 rows
            local kids = StepBox:GetChildren()
            if #kids > 5 then kids[1]:Destroy() end
        end

        task.wait(0.35)

        -- ── Slide card off + fade background ────
        Tw(Card, {Position = UDim2.new(0.5, 0, -0.15, 0)},
           0.65, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        Tw(LoadFrame,  {BackgroundTransparency = 1}, 0.7)
        Tw(Overlay,    {BackgroundTransparency = 1}, 0.5)
        task.wait(0.8)
        pcall(function() LoadFrame:Destroy() end)

        -- ── Remove blur ─────────────────────────
        Tw(blurFx, {Size = 0}, 0.85)
        task.wait(0.95)
        pcall(function() blurFx:Destroy() end)

        -- ── Fade out music ──────────────────────
        if loadMusic then
            Tw(loadMusic, {Volume = 0}, 0.85)
            task.wait(0.95)
            pcall(function() loadMusic:Stop() loadMusic:Destroy() end)
        end

        -- ── Build settings tab ──────────────────
        BuildSettingsTab()

        -- ── Reveal main window ──────────────────
        Win.Loaded                  = true   -- signal to outside code: safe to show ESP
        Main.BackgroundTransparency = 1
        Main.Visible                = true
        Tw(Main, {BackgroundTransparency = 0}, 0.4)

        -- Make sure first user tab is active
        if Win.Tabs[1] then
            for _, t in ipairs(Win.Tabs) do
                t.Content.Visible = false
                Tw(t.Button, {BackgroundTransparency = 0.55, TextColor3 = C.TxtSub})
            end
            Win.Tabs[1].Content.Visible               = true
            Win.Tabs[1].Button.BackgroundTransparency = 0
            Win.Tabs[1].Button.TextColor3             = C.TxtHi
        end
    end)

    Win.Main = Main
    return Win
end

return Library
