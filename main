    local loadMusic = nil
    if musicId then
        loadMusic = Instance.new("Sound")
        loadMusic.SoundId  = musicId
        loadMusic.Volume   = 0.55
        loadMusic.Looped   = true
        loadMusic.RollOffMaxDistance = 99999
        if not pcall(function() loadMusic.Parent = workspace end) then
            loadMusic.Parent = LocalPlayer.PlayerGui
        end
        loadMusic:Play()
