if CoreGui:FindFirstChild("DRXGUI") then
    CoreGui:FindFirstChild("DRXGUI"):Destroy()
    task.wait(0.1)
end

-- ════════════════════════════════════════════════
-- THEME
-- ════════════════════════════════════════════════
local C = {
    BG       = Color3.fromRGB(14,  14,  18),
    Surface  = Color3.fromRGB(22,  22,  28),
    Elevated = Color3.fromRGB(30,  30,  38),
    Primary  = Color3.fromRGB(100, 100, 255),
    Success  = Color3.fromRGB(34,  197, 94),
    Error    = Color3.fromRGB(239, 68,  68),
    Warn     = Color3.fromRGB(234, 179, 8),
    TxtHi    = Color3.fromRGB(255, 255, 255),
    TxtSub   = Color3.fromRGB(140, 140, 160),
    Border   = Color3.fromRGB(42,  42,  55),
    LoadBG   = Color3.fromRGB(8,   8,   12),
}

-- ════════════════════════════════════════════════
-- HELPERS
-- ════════════════════════════════════════════════
local function Corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = p
end

local function Stroke(p, col, th)
    local s = Instance.new("UIStroke")
    s.Color     = col or C.Border
    s.Thickness = th  or 1
    s.Parent    = p
end

local function Pad(p, t, b, l, r)
    local pd = Instance.new("UIPadding")
    pd.PaddingTop    = UDim.new(0, t or 0)
    pd.PaddingBottom = UDim.new(0, b or 0)
    pd.PaddingLeft   = UDim.new(0, l or 0)
    pd.PaddingRight  = UDim.new(0, r or 0)
    pd.Parent        = p
end

local function Tw(obj, props, dur, style, dir)
    local t = TweenService:Create(
        obj,
        TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

-- ════════════════════════════════════════════════
-- CONFIG FILE SYSTEM
-- ════════════════════════════════════════════════
local FOLDER = "DRX_Configs"

local function EnsureFolder()
    if isfolder and not isfolder(FOLDER) then pcall(makefolder, FOLDER) end
end

local function GetConfigList()
    if not isfolder then return {} end
    EnsureFolder()
    local ok, files = pcall(listfiles, FOLDER)
    if not ok then return {} end
    local out = {}
    for _, f in ipairs(files) do
        local n = f:match("([^/\\]+)$")
        if n then table.insert(out, (n:gsub("%.json$", ""))) end
    end
    return out
end

local function SaveCfg(name, data)
    if not writefile then return false end
    EnsureFolder()
    return pcall(writefile, FOLDER.."/"..name..".json", HttpService:JSONEncode(data))
end

local function LoadCfg(name)
    if not readfile then return nil end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(FOLDER.."/"..name..".json"))
    end)
    return ok and data or nil
end

local function DeleteCfg(name)
    if not delfile then return false end
    return pcall(delfile, FOLDER.."/"..name..".json")
end

